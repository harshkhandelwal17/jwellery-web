{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build:deps": "cd ../.. && pnpm --filter @jwell/types build && pnpm --filter @jwell/utils build",
    "build": "pnpm run build:deps && tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "seed": "tsx src/seed.ts",
    "upload-images": "tsx src/scripts/upload-images.ts",
    "upload-shreeva": "tsx src/scripts/upload-shreeva.ts"
  },
  "dependencies": {
    "@jwell/types": "workspace:*",
    "@jwell/utils": "workspace:*",
    "cloudinary": "^2.5.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongoose": "^8.9.5",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
