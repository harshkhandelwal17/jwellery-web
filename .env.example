# ========================================
# LOCAL DEV (repo root: copy to .env — never commit .env)
# ========================================
# Production uses Vercel env vars per project (see sections below).

# --- API (apps/api) — local + same keys on Vercel API project ---
PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE
ADMIN_API_KEY=your-admin-secret-key-here
# CORS: API allows all browser origins (no allowlist). Optional override not used in code.
# CORS_ORIGINS=...

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

WEB_URL=http://localhost:3000
REVALIDATE_SECRET=your-revalidation-secret-key

# --- Web (apps/web) — local + same keys on Vercel WEB project ---
NEXT_PUBLIC_API_URL=http://localhost:4000/api
API_URL=http://localhost:4000/api

# --- Admin build (embedded in web build) — set on Vercel WEB project ---
VITE_API_URL=http://localhost:4000/api
VITE_ADMIN_API_KEY=your-admin-secret-key-here

# ========================================
# VERCEL — API project only (Root Directory: apps/api)
# Example host: https://jwellery-web-api-qzho.vercel.app
# ========================================
# MONGODB_URI           (required — Atlas connection string)
# ADMIN_API_KEY
# CORS_ORIGINS          include https://jwellery-web-web.vercel.app (no trailing slash)
# CLOUDINARY_*          if you use uploads
# WEB_URL               https://jwellery-web-web.vercel.app
# REVALIDATE_SECRET     match web project if you use revalidate webhook

# ========================================
# VERCEL — WEB project only (Root Directory: apps/web)
# Example host: https://jwellery-web-web.vercel.app
# ========================================
# NEXT_PUBLIC_API_URL   https://jwellery-web-api-qzho.vercel.app/api
# API_URL               same as NEXT_PUBLIC_API_URL (server-side fetch)
# VITE_API_URL          same (admin bundle at build time)
# VITE_ADMIN_API_KEY    same as ADMIN_API_KEY on API
# REVALIDATE_SECRET     if /api/revalidate is used
